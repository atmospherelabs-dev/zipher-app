#!/usr/bin/env node

const { execFileSync } = require("child_process");
const path = require("path");
const fs = require("fs");

const bin = path.join(__dirname, "zipher-mcp-server");

if (!fs.existsSync(bin)) {
  console.error("zipher-mcp-server binary not found. Run: npm rebuild @cipherpay/zipher-cli");
  process.exit(1);
}

try {
  execFileSync(bin, process.argv.slice(2), { stdio: "inherit" });
} catch (err) {
  process.exit(err.status || 1);
}
