#!/usr/bin/env node

const { execFileSync } = require("child_process");
const path = require("path");
const fs = require("fs");

const bin = path.join(__dirname, process.platform === "win32" ? "zipher-cli.exe" : "zipher-cli");

if (!fs.existsSync(bin)) {
  console.error("zipher-cli binary not found. Run: npm rebuild @atmospherelabs/zipher-cli");
  process.exit(1);
}

try {
  execFileSync(bin, process.argv.slice(2), { stdio: "inherit" });
} catch (err) {
  process.exit(err.status || 1);
}
